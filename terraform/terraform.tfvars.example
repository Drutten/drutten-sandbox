# Example terraform variables file
# Copy this to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored for security

project_id = "your-gcp-project-id"
region     = "europe-west1"

# The api service is enabled by default. Override services here to customize it
# or add more deployable applications. CI moves each service's latest tag only
# after a successful build; Terraform resolves that tag to an immutable digest.
